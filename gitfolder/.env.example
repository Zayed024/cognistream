# CogniStream — Environment Variables
# Copy to .env and adjust as needed.

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=moondream
OLLAMA_TIMEOUT=120

# ChromaDB (empty = embedded mode, set host for Docker)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=gpu
WHISPER_COMPUTE_TYPE=int8

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Video limits
MAX_VIDEO_SIZE_MB=2048
MAX_KEYFRAMES=200

# Shot detection
SHOT_THRESHOLD=0.45
MIN_SEGMENT_FRAMES=15

# Pipeline mode: "fast" (single-pass VLM, parallel) or "quality" (4-pass VLM)
PIPELINE_MODE=fast

# Streaming chunk size in seconds (for live/chunked processing)
STREAM_CHUNK_SEC=30

# ── NVIDIA NIM Cloud (optional) ──────────────
# Set your API key to enable NVIDIA cloud models for higher quality.
# Leave empty to use local models only (Ollama + Whisper).
# Get a key at: https://build.nvidia.com/
NVIDIA_API_KEY=
# NVIDIA_VLM_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
# NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
# NVIDIA_ASR_MODEL=nvidia/parakeet-ctc-1_1b-asr
# NVIDIA_CLIP_MODEL=nvidia/nvclip
# NVIDIA_GROUNDING_MODEL=nvidia/nv-grounding-dino

# Logging
LOG_LEVEL=INFO
