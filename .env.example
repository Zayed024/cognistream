# CogniStream — Environment Variables
# Copy to .env and adjust as needed.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=moondream
OLLAMA_TIMEOUT=120

# ChromaDB (empty = embedded mode, set host for Docker)
CHROMA_HOST=
CHROMA_PORT=8000

# Whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Video limits
MAX_VIDEO_SIZE_MB=2048
MAX_KEYFRAMES=200

# Shot detection
SHOT_THRESHOLD=0.45
MIN_SEGMENT_FRAMES=15

# Pipeline mode: "fast" (single-pass VLM, parallel) or "quality" (4-pass VLM)
PIPELINE_MODE=fast

# Streaming chunk size in seconds (for live/chunked processing)
STREAM_CHUNK_SEC=30

# Parallel processing workers
# AUTO_TUNE_PIPELINE: 1=adaptive hardware-based worker sizing
AUTO_TUNE_PIPELINE=1
# VLM_WORKERS: 0=auto (1 local, 4 NVIDIA), 1=sequential, 2+=concurrent
VLM_WORKERS=0
# SHOT_DETECTION_WORKERS: parallel chunks for shot boundary detection
SHOT_DETECTION_WORKERS=0

# Keyframe novelty filter (drops near-duplicate frames before VLM)
KEYFRAME_NOVELTY_FILTER=1
KEYFRAME_NOVELTY_DIFF_THRESHOLD=9.0
KEYFRAME_NOVELTY_MAX_SKIP=8
KEYFRAME_NOVELTY_MIN_KEEP=40

# ── Security ─────────────────────────────────
# API key auth (empty = no auth, for local dev)
# Multiple keys can be comma-separated for multi-user: key1,key2,key3
COGNISTREAM_API_KEY=
# Rate limit (requests per minute per IP, 0 = disabled)
RATE_LIMIT_RPM=120

# ── NVIDIA NIM Cloud (optional) ──────────────
# Set your API key to enable NVIDIA cloud models for higher quality.
# Leave empty to use local models only (Ollama + Whisper).
# Get a key at: https://build.nvidia.com/
NVIDIA_API_KEY=
# NVIDIA_VLM_MODEL=meta/llama-3.2-11b-vision-instruct
# NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
# NVIDIA_ASR_MODEL=nvidia/parakeet-ctc-1_1b-asr
# NVIDIA_CLIP_MODEL=nvidia/nvclip-vit-h-14
# NVIDIA_GROUNDING_MODEL=nvidia/nv-grounding-dino

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=1
LOG_FILE_LEVEL=DEBUG
