# CogniStream — Environment Variables
# Copy to .env and adjust as needed.

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=moondream
OLLAMA_TIMEOUT=120

# ChromaDB (empty = embedded mode, set host for Docker)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Whisper
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Video limits
MAX_VIDEO_SIZE_MB=2048
MAX_KEYFRAMES=200

# Shot detection
SHOT_THRESHOLD=0.45
MIN_SEGMENT_FRAMES=15

# Logging
LOG_LEVEL=INFO
